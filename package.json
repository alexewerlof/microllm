{
    "name": "microllm",
    "description": "A minimalistic library to run Small Language Models (SLMs) in JavaScript, supporting Node.js and browsers.",
    "version": "0.1.0",
    "main": "./lib/index.js",
    "type": "module",
    "directories": {
        "lib": "lib",
        "doc": "doc",
        "test": "test"
    },
    "files": [
        "lib",
        "README.md"
    ],
    "exports": {
        "import": "./lib/index.js",
        "require": "./lib/index.cjs"
    },
    "scripts": {
        "fmt": "prettier --write .",
        "lint": "eslint",
        "typecheck": "tsc --noEmit",
        "test": "node --import tsx --test",
        "doc": "typedoc src/index.ts",
        "prebuild": "rm -rf lib doc",
        "build": "tsup --dts && npm run doc",
        "preversion": "npm run fmt && npm t",
        "prepublishOnly": "npm run build",
        "postversion": "git push && git push --tags"
    },
    "keywords": [
        "javascript",
        "typescript",
        "small language model",
        "llm",
        "slm",
        "ai",
        "node",
        "browser",
        "openai-compatible",
        "retrieval-augmented generation",
        "RAG",
        "tool-calling"
    ],
    "dependencies": {
        "@huggingface/transformers": "^3.8.1",
        "jty": "^5.1.0",
        "onnxruntime-node": "^1.21.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/cli-progress": "^3.11.6",
        "@types/node": "^25.5.0",
        "cli-progress": "^3.12.0",
        "eslint": "^10.0.3",
        "globals": "^17.4.0",
        "jiti": "^2.6.1",
        "prettier": "^3.8.1",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typedoc": "^0.28.17",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/alexewerlof/microllm.git"
    },
    "author": "Alex Ewerlöf",
    "license": "MIT"
}
