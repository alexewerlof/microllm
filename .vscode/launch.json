{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug node-agentic-loop.ts",
      "skipFiles": ["<node_internals>/**"],
      "program": "example/node-agentic-loop.ts",
      "runtimeExecutable": "/opt/nvm/versions/node/v24.14.0/bin/npx",
      "runtimeArgs": ["tsx", "--no-cache"],
      "cwd": "${workspaceFolder}",
      "outFiles": ["${workspaceFolder}/**/*.js"],
      "sourceMaps": true,
      "env": {
        "PATH": "/opt/nvm/versions/node/v24.14.0/bin:/usr/bin:/bin" // Add the path to node here
      }
    }
  ]
}